generator client {
  provider = "prisma-client-js"
  // output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String @id @default(uuid())
  email       String
  
  firstName   String?
  lastName    String?
  imageUrl    String?
  
  clerkUserId String @unique
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  settings    UserSettings?
  habits      Habit[]
  tasks       Task[]
  moodEntry   MoodEntry[]
  annotations Annotations[]

  routines    Routine[]
  goals       Goals[]
  categories  Categories[]
}

model UserSettings {
  userId String @id @map("user_id")

  notificationsEnabled Boolean @default(true)  @map("notifications_enabled")
  emailNotifications   Boolean @default(true)  @map("email_notifications")
  smsNotifications     Boolean @default(false) @map("sms_notifications")

  email     String? @map("email")
  phone     String? @map("phone")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

enum HabitStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

model Habit {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")

  name          String    @db.VarChar(255)
  emoji         String?   @db.VarChar(10)

  customField   String?   @map("custom_field") @db.VarChar(12)
  limitCounter  Int?      @default(1)

  clock         String?   @db.VarChar(8) // HH:mm:ss       // horário definido do hábito
  duration      String?   @db.VarChar(8) //DURAÇÃO DE UM HÁBITO

  status        HabitStatus @default(ACTIVE)

  startDate     DateTime   @default(now()) @map("start_date")
  endDate       DateTime?  @map("end_date")

  reminder      Boolean?   @default(false)
  frequency     Json?      @default("[\"S\",\"M\",\"T\",\"W\",\"TH\",\"F\",\"SA\"]")
  color         String?    @default("#3B82F6") @db.VarChar(7)

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime? @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  indexPos      Int?

  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)

  schedules   HabitSchedule[]
  completions HabitCompletion[]

  goals       Goals[]
  categories  Categories[]

  @@index([indexPos])
  @@index([userId])
  @@map("habits")
}

model Task {
  id            String      @id @default(uuid())
  userId        String      @map("user_id")

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  name          String      @db.VarChar(100)
  description   String?     @db.VarChar(255)
  emoji         String?     @db.VarChar(10)

  customField   String?     @map("custom_field") @db.VarChar(12)
  limitCounter  Int?        @default(1)

  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime?   @updatedAt @map("updated_at")
  deletedAt     DateTime?   @map("deleted_at")

  indexPos      Int?
  status        HabitStatus   @default(ACTIVE)

  schedules     TaskSchedule[]
  completions   TaskCompletion[]
  goals         Goals[]
  categories    Categories[]

  checkpointId  String?  @map("checkpoint_id")
  checkpoints   CheckPoint[]

  @@index([indexPos])
  @@index([userId])
  @@map("task")
}

model CheckPoint {
  id          String    @id @unique @default(uuid())
  userId      String                    @map("user_id")

  name        String    @db.VarChar(100)
  description String?   @db.VarChar(255)

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt      @map("updated_at")
  deletedAt   DateTime?                 @map("deleted_at")

  startDate   DateTime  @default(now()) @map("start_date")
  endDate     DateTime?                 @map("end_date")
  
  goal  Goals[]

  tasks Task[]
  @@map("checkpoint")
}

model TaskCompletion {
  id          String      @id @default(uuid())

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime? @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  completedDate DateTime  @map("completed_date")
  counter       Int? @default(0)// null = conta apenas 1 vez
  isCompleted   Boolean?  @default(false) @map("is_completed")
  
  taskId        String    @map("task_id")
  task          Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  annotations   Annotations[]

  @@unique([taskId, completedDate])
  @@index([completedDate])
  @@map("task_completion")
}

model Routine {
  id          String    @id @default(uuid())
  userId      String @map("user_id")

  user        User @relation(fields: [userId], references: [id])

  name        String
  description String?

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt  @map("updated_at")

  startDate   DateTime  @default(now()) @map("start_date")
  endDate     DateTime? @map("end_date")

  cron        String?   @default("")
  frequency   Json?     @default("[\"M\",\"T\",\"W\",\"T\",\"F\",\"S\",\"S\"]")
  emoji       String?    @db.VarChar(10) @default("")

  status      HabitStatus    @default(ACTIVE)

  habitSchedules HabitSchedule[]
  taskSchedules  TaskSchedule[]

  @@map("routine")
}

model TaskSchedule {
  id            String    @unique @id @default(uuid())

  duration      String    @db.VarChar(20)
  clock         String    @db.VarChar(20)

  status        HabitStatus    @default(ACTIVE)

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime? @updatedAt      @map("updated_at")

  routineId     String    @map("routine_id")
  routine       Routine   @relation(fields: [routineId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  taskId        String    @map("task_id")
  task          Task      @relation(fields: [taskId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  @@unique([routineId, clock])
  @@index([routineId, clock])
  @@map("task_schedule")
}

model HabitSchedule {
  id            String    @unique @id @default(uuid())

  duration      String?    @db.VarChar(20)
  clock         String?    @db.VarChar(20)

  status        HabitStatus    @default(ACTIVE)

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime? @updatedAt      @map("updated_at")

  routineId     String?    @map("routine_id")
  routine       Routine?   @relation(fields: [routineId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  habitId       String?    @map("habit_id")
  habit         Habit?     @relation(fields: [habitId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  @@unique([routineId, clock])
  @@index([routineId, clock])
  @@map("habit_schedule")
}

model HabitCompletion {
  id            String @id @default(uuid())

  habitId       String @map("habit_id")

  completedDate DateTime? @map("completed_date")
  counter       Int? @default(0)            // null = conta apenas 1 vez

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime? @updatedAt      @map("updated_at")

  habit       Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)
  annotations Annotations?

  @@unique([habitId, completedDate])
  @@map("habit_completions")
}

model MoodEntry {
  id      String      @id @default(uuid())
  userId  String      @map("user_id")

  moodType  String    @db.VarChar(50) @map("mood_type")
  moodLevel String    @db.VarChar(50) @map("mood_level")
  entryDate DateTime  @default(now()) @map("entry_date")
  
  createdAt DateTime  @default(now()) 
  updatedAt DateTime? @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, entryDate])
  @@index([entryDate])
  @@index([userId])
  @@map("mood_entries")
}

model Goals {
  id            String  @id @default(uuid())
  userId        String @map("user_id")

  user          User @relation(fields: [userId], references: [id])

  name          String
  description   String?
  emoji         String?   @db.VarChar(10)

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime? @updatedAt      @map("updated_at")

  habits        Habit[]

  tasks         Task[]
  checkpoints   CheckPoint[]

  status        HabitStatus? @default(ACTIVE)
  @@map("goals")
}

model Categories {
  id            String  @id @default(uuid())
  userId        String @map("user_id")

  user User @relation(fields: [userId], references: [id])

  name          String
  description   String?
  emoji         String?   @db.VarChar(10)
  color         String?   @db.VarChar(7)

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime? @updatedAt      @map("updated_at")

  habits        Habit[]
  tasks         Task[]

  status        HabitStatus? @default(ACTIVE)
  @@map("categories")
}

model Annotations {
  id           String  @id @default(uuid())
  userId       String @map("user_id")

  user         User @relation(fields: [userId], references: [id])

  name         String
  content      String?
  
  createdByAI  Boolean? @default(false) @map("created_by_ai")
  summary      String?

  imageUrl     String? @db.VarChar(255)

  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime?  @updatedAt      @map("updated_at")

  completionId String @unique @map("completion_id")
  completion       HabitCompletion @relation(fields: [completionId], references: [id], onDelete: Cascade)

  tasksCompletions TaskCompletion[]
  @@map("annotations")
}

