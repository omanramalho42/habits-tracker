generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String        @id @default(uuid())
  email       String
  firstName   String?
  lastName    String?
  imageUrl    String?
  clerkUserId String        @unique
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  Task        Task[]
  categories  Categories[]
  habits      Habit[]
  moodEntry   MoodEntry[]
  settings    UserSettings?
}

model UserSettings {
  userId               String   @id @map("user_id")
  notificationsEnabled Boolean  @default(true) @map("notifications_enabled")
  emailNotifications   Boolean  @default(true) @map("email_notifications")
  smsNotifications     Boolean  @default(false) @map("sms_notifications")
  email                String?  @map("email")
  phone                String?  @map("phone")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model Habit {
  id           String            @id @default(uuid())
  name         String            @db.VarChar(255)
  emoji        String?           @db.VarChar(10)
  startDate    DateTime          @default(now()) @map("start_date")
  reminder     Boolean?          @default(false)
  frequency    Json?             @default("[\"S\", \"M\", \"T\", \"W\", \"TH\", \"F\", \"SA\"]")
  color        String?           @default("#3B82F6") @db.VarChar(7)
  createdAt    DateTime          @default(now()) @map("created_at")
  endDate      DateTime?         @map("end_date")
  userId       String            @map("user_id")
  deletedAt    DateTime?         @map("deleted_at")
  status       HabitStatus       @default(ACTIVE)
  updatedAt    DateTime?         @updatedAt @map("updated_at")
  clock        String?           @db.VarChar(8)
  limitCounter Int?              @default(1)
  duration     String?           @db.VarChar(8)
  customField  String?           @map("custom_field") @db.VarChar(12)
  indexPos     Int?
  completions  HabitCompletion[]
  schedules    HabitSchedule[]
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  categories   Categories[]      @relation("CategoriesToHabit")
  goals        Goals[]           @relation("GoalsToHabit")

  @@index([indexPos])
  @@index([userId])
  @@map("habits")
}

model CheckPoint {
  id               String             @id @unique @default(uuid())
  userId           String             @map("user_id")
  name             String             @db.VarChar(100)
  description      String?            @db.VarChar(255)
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime?          @updatedAt @map("updated_at")
  deletedAt        DateTime?          @map("deleted_at")
  startDate        DateTime           @default(now()) @map("start_date")
  endDate          DateTime?          @map("end_date")
  CheckPointToTask CheckPointToTask[]
  goal             Goals[]            @relation("CheckPointToGoals")

  @@map("checkpoint")
}

model TaskCompletion {
  id            String        @id @default(uuid())
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime?     @updatedAt @map("updated_at")
  deletedAt     DateTime?     @map("deleted_at")
  completedDate DateTime      @map("completed_date")
  isCompleted   Boolean?      @default(false) @map("is_completed")
  taskId        String        @map("task_id")
  task          Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  annotations   Annotations[] @relation("AnnotationsToTaskCompletion")

  @@unique([taskId, completedDate])
  @@index([completedDate])
  @@map("task_completion")
}

model Routine {
  id             String          @id @default(uuid())
  userId         String          @map("user_id")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime?       @updatedAt @map("updated_at")
  startDate      DateTime        @default(now()) @map("start_date")
  endDate        DateTime?       @map("end_date")
  cron           String?         @default("")
  frequency      Json?           @default("[\"M\", \"T\", \"W\", \"T\", \"F\", \"S\", \"S\"]")
  emoji          String?         @default("") @db.VarChar(10)
  status         HabitStatus     @default(ACTIVE)
  description    String?
  name           String
  habitSchedules HabitSchedule[]
  taskSchedules  TaskSchedule[]

  @@map("routine")
}

model TaskSchedule {
  id        String      @id @unique @default(uuid())
  duration  String      @db.VarChar(20)
  clock     String      @db.VarChar(20)
  status    HabitStatus @default(ACTIVE)
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime?   @updatedAt @map("updated_at")
  routineId String      @map("routine_id")
  taskId    String      @map("task_id")
  routine   Routine     @relation(fields: [routineId], references: [id], onDelete: Cascade)
  task      Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([routineId, clock])
  @@index([routineId, clock])
  @@map("task_schedule")
}

model HabitSchedule {
  id        String      @id @unique @default(uuid())
  duration  String?     @db.VarChar(20)
  clock     String?     @db.VarChar(20)
  status    HabitStatus @default(ACTIVE)
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime?   @updatedAt @map("updated_at")
  routineId String?     @map("routine_id")
  habitId   String?     @map("habit_id")
  habit     Habit?      @relation(fields: [habitId], references: [id], onDelete: Cascade)
  routine   Routine?    @relation(fields: [routineId], references: [id], onDelete: Cascade)

  @@unique([routineId, clock])
  @@index([routineId, clock])
  @@map("habit_schedule")
}

model HabitCompletion {
  id            String       @id @default(uuid())
  habitId       String       @map("habit_id")
  counter       Int?         @default(0)
  completedDate DateTime?    @map("completed_date")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime?    @updatedAt @map("updated_at")
  annotations   Annotations?
  habit         Habit        @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, completedDate])
  @@map("habit_completions")
}

model MoodEntry {
  id        String    @id @default(uuid())
  moodType  String    @map("mood_type") @db.VarChar(50)
  moodLevel String    @map("mood_level") @db.VarChar(50)
  entryDate DateTime  @default(now()) @map("entry_date")
  userId    String    @map("user_id")
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, entryDate])
  @@index([entryDate])
  @@index([userId])
  @@map("mood_entries")
}

model Goals {
  id          String        @id @default(uuid())
  name        String
  description String?
  emoji       String?       @db.VarChar(10)
  userId      String        @map("user_id")
  status      HabitStatus?  @default(ACTIVE)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime?     @updatedAt @map("updated_at")
  GoalsToTask GoalsToTask[]
  checkpoints CheckPoint[]  @relation("CheckPointToGoals")
  habits      Habit[]       @relation("GoalsToHabit")

  @@map("goals")
}

model Categories {
  id               String             @id @default(uuid())
  userId           String             @map("user_id")
  name             String
  description      String?
  emoji            String?            @db.VarChar(10)
  color            String?            @db.VarChar(7)
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime?          @updatedAt @map("updated_at")
  status           HabitStatus?       @default(ACTIVE)
  CategoriesToTask CategoriesToTask[]
  user             User               @relation(fields: [userId], references: [id])
  habits           Habit[]            @relation("CategoriesToHabit")

  @@map("categories")
}

model Annotations {
  id               String           @id @default(uuid())
  name             String
  content          String?
  completionId     String           @unique @map("completion_id")
  summary          String?
  imageUrl         String?          @db.VarChar(255)
  createdAt        DateTime         @default(now()) @map("created_at")
  createdByAI      Boolean?         @default(false) @map("created_by_ai")
  updatedAt        DateTime?        @updatedAt @map("updated_at")
  completion       HabitCompletion  @relation(fields: [completionId], references: [id], onDelete: Cascade)
  tasksCompletions TaskCompletion[] @relation("AnnotationsToTaskCompletion")

  @@map("annotations")
}

model Task {
  id               String             @id
  user_id          String
  name             String             @db.VarChar(100)
  description      String?            @db.VarChar(255)
  created_at       DateTime           @default(now())
  updated_at       DateTime?
  deleted_at       DateTime?
  status           HabitStatus        @default(ACTIVE)
  checkpoint_id    String?
  custom_field     String?            @db.VarChar(12)
  emoji            String?            @db.VarChar(10)
  limitCounter     Int?               @default(1)
  User             User               @relation(fields: [user_id], references: [id])
  CategoriesToTask CategoriesToTask[]
  CheckPointToTask CheckPointToTask[]
  GoalsToTask      GoalsToTask[]
  completions      TaskCompletion[]
  schedules        TaskSchedule[]
}

model CategoriesToTask {
  A          String
  B          String
  categories Categories @relation(fields: [A], references: [id], onDelete: Cascade)
  Task       Task       @relation(fields: [B], references: [id], onDelete: Cascade)

  @@id([A, B], map: "_CategoriesToTask_AB_pkey")
  @@index([B], map: "_CategoriesToTask_B_index")
  @@map("_CategoriesToTask")
}

model CheckPointToTask {
  A          String
  B          String
  checkpoint CheckPoint @relation(fields: [A], references: [id], onDelete: Cascade)
  Task       Task       @relation(fields: [B], references: [id], onDelete: Cascade)

  @@id([A, B], map: "_CheckPointToTask_AB_pkey")
  @@index([B], map: "_CheckPointToTask_B_index")
  @@map("_CheckPointToTask")
}

model GoalsToTask {
  A     String
  B     String
  goals Goals  @relation(fields: [A], references: [id], onDelete: Cascade)
  Task  Task   @relation(fields: [B], references: [id], onDelete: Cascade)

  @@id([A, B], map: "_GoalsToTask_AB_pkey")
  @@index([B], map: "_GoalsToTask_B_index")
  @@map("_GoalsToTask")
}

enum HabitStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}
