// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  // output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
  STARTER
  PREMIUM
}

// Novo Schema para controlar limites de IA e acessos
model UserUsage {
  id                String   @id @default(uuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  aiGenerationsUsed Int      @default(0)
  aiLimit           Int      @default(5) // Limite default para USER
  
  // Outros limites que você pode querer controlar
  maxHabits         Int      @default(10)
  canUseVoice       Boolean  @default(false)

  lastReset         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Notification {
  id                String   @id @default(uuid())
  user_id           String   @unique // <--- O @unique é obrigatório aqui
  notification_json String   // Aqui você armazena o JSON da subscrição (push subscription)
  createdAt         DateTime @default(now())

  // Definindo o relacionamento
  user              User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("notification")
}

model User {
  id          String @id @default(uuid())
  email       String
  
  firstName   String?
  lastName    String?
  imageUrl    String?
  
  clerkUserId String @unique

  // 2. Atualize o campo role para usar o Enum
  role         Role     @default(USER)
  // Relacionamento com o esquema de limites
  usage        UserUsage?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  settings    UserSettings?
  habits      Habit[]
  tasks       Task[]
  moodEntry   MoodEntry[]
  annotations Annotations[]

  // Relacionamento: Um usuário pode ter várias notificações
  notifications Notification[]

  routines    Routine[]
  goals       Goals[]
  categories  Categories[]
  feedbacks   Feedback[]
  posts       Post[]
  counters    Counter[]
  assistents  Assistant[]
}

enum THEME {
  light
  dark
}

enum PixKeyType {
  CPF
  EMAIL
  PHONE
  RANDOM
}
enum HABIT_LAYOUT {
  VERTICAL
  HORIZONTAL
}

model UserSettings {
  userId String @id @map("user_id")

  bannerUrl String? @db.VarChar(255) @map("banner_url")
  avatarUrl String? @db.VarChar(255) @map("avatar_url")
  theme     THEME?  @default(dark)

  notificationsEnabled Boolean? @default(false)  @map("notifications_enabled")
  emailNotifications   Boolean? @default(false)  @map("email_notifications")
  smsNotifications     Boolean? @default(false) @map("sms_notifications")

  // 👇 NOVAS PREFERÊNCIAS
  showGraphs Boolean? @default(true) @map("show_graphs")

  habitLayout HABIT_LAYOUT? @default(VERTICAL) @map("habit_layout")

  name       String?      @db.VarChar(100)
  email      String?      @map("email")
  phone      String?      @map("phone")
  pixKey     String?      @map("pix_key") @db.VarChar(255)
  pixKeyType PixKeyType?  @default(CPF) @map("pix_key_type")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt      @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

enum HabitStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

model Habit {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")

  name          String    @db.VarChar(255)
  emoji         String?   @db.VarChar(10)

  customField   String?   @map("custom_field") @db.VarChar(12)
  limitCounter  Int?      @default(1)

  clock         String?   @db.VarChar(8) // HH:mm:ss       // horário definido do hábito
  duration      String?   @db.VarChar(8) //DURAÇÃO DE UM HÁBITO

  status        HabitStatus @default(ACTIVE)

  startDate     DateTime   @default(now()) @map("start_date")
  endDate       DateTime?  @map("end_date")

  reminder      Boolean?   @default(false)
  frequency     Json?      @default("[\"S\",\"M\",\"T\",\"W\",\"TH\",\"F\",\"SA\"]")
  color         String?    @default("#3B82F6") @db.VarChar(7)

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime? @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  indexPos      Int?

  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)

  schedules   HabitSchedule[]
  completions HabitCompletion[]

  goals       Goals[]
  categories  Categories[]

  @@index([indexPos])
  @@index([userId])
  @@map("habits")
}

model CheckPoint {
  id          String    @id @unique @default(uuid())
  userId      String                    @map("user_id")

  name        String    @db.VarChar(100)
  description String?   @db.VarChar(255)

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt      @map("updated_at")
  deletedAt   DateTime?                 @map("deleted_at")

  startDate   DateTime  @default(now()) @map("start_date")
  endDate     DateTime?                 @map("end_date")
  
  goal  Goals[]

  tasks Task[]
  @@map("checkpoint")
}

model Frequency {
  id  String  @id @default(uuid())

  name          String      @db.VarChar(100)
  description   String?     @db.VarChar(255)
  emoji         String?     @db.VarChar(10)
  color         String?     @db.VarChar(10)

  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime?   @updatedAt @map("updated_at")
  deletedAt     DateTime?   @map("deleted_at")

  value Json

  task Task[]
  cron Cron[]

  status HabitStatus  @default(ACTIVE)
  
  @@map("frequencu")
}

model Cron {
  id  String  @id @default(uuid())

  name          String      @db.VarChar(50)
  description   String?     @db.VarChar(255)
  emoji         String?     @db.VarChar(10)
  color         String?     @db.VarChar(10)
  
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime?   @updatedAt @map("updated_at")
  deletedAt     DateTime?   @map("deleted_at")

  value         String

  task   Task[]
  status HabitStatus  @default(ACTIVE)

  frequency Frequency[]
  @@map("cron")
}

enum MetricType {
  NUMERIC
  STRING
  FLOAT
}

model CounterStep {
  id          String   @id @default(uuid())

  date        DateTime
  currentStep Int      @default(0)
  limit       Int

  counterId   String   @map("counter_id")
  counter     Counter  @relation(fields: [counterId], references: [id], onDelete: Cascade)

  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime?   @updatedAt @map("updated_at")

  completionId String @unique @map("completion_id")
  completion TaskCompletion @relation(fields: [completionId], references: [id])

  @@unique([counterId, date, completionId]) // 🔥 UM POR DIA
  @@map("counter_step")
}

model Counter {
  id           String  @id @default(uuid())

  label        String  @db.VarChar(20)
  emoji        String? @db.VarChar(20)

  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime?   @updatedAt @map("updated_at")
  deletedAt    DateTime?   @map("deleted_at")

  status       HabitStatus? @default(ACTIVE)

  valueNumber Float?    @default(0)
  valueText   String?   @db.VarChar(20) 
  unit        String?

  userId      String?
  user        User? @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  limit       Int     @default(1)

  // taskMetric TaskMetric[]
  // taskCompletion TaskCompletion[]
  task       Task[]
  CounterStep CounterStep[]

  @@unique([userId, label, valueNumber, unit])
  @@map("counter")
}

model Assistant {
  id              String    @id @default(cuid())

  userId      String?
  user        User? @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  name            String
  
  // Relacionamento com Emoji (Mascote)
  emojiId         String    @map("emoji_id")
  emoji           Emoji     @relation(fields: [emojiId], references: [id])
  
  prompt          String?   @db.Text
  voiceId         String?   @map("voice_id")
  
  // Parâmetros de IA
  temperature     Float     @default(0.7)
  creativity      Float     @default(0.5)
  memoryEnabled   Boolean   @default(true) @map("memory_enabled")
  
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@map("assistants")
}

model Emoji {
  id        String      @id @default(uuid())
  name      String
  imageUrl  String      @map("image_url")

  // Relacionamento com Task (se existir)
  taskId    String?     @unique @map("task_id")
  task      Task?       @relation(fields: [taskId], references: [id])

  // Relacionamento com Assistant
  assistants Assistant[]

  status    HabitStatus @default(ACTIVE)

  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime?   @updatedAt @map("updated_at")
  deletedAt DateTime?   @map("deleted_at")

  @@map("emoji")
}

model Task {
  id            String      @id @default(uuid())

  userId        String      @map("user_id")
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  name          String      @db.VarChar(100)

  description   String?     @db.VarChar(255)
  
  emoji         String?     @db.VarChar(10)
  emojiUrl      Emoji[]

  color         String?     @db.VarChar(10)

  imageUrl      String?     @db.VarChar(255) @map("image_url")
  videoUrl      String?     @db.VarChar(255) @map("video_url")

  isVisible     Boolean?    @default(false)
  isPlus        Boolean?    @default(true)

  //REMOVER
  customField   String?     @map("custom_field") @db.VarChar(12)
  //REMOVER
  limitCounter  Int?        @default(1) @map("limit_counter")

  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime?   @updatedAt @map("updated_at")
  deletedAt     DateTime?   @map("deleted_at")

  counterId     String?
  counter       Counter? @relation(fields: [counterId], references: [id])

  cronId        String?
  cron          Cron? @relation(fields: [cronId], references: [id])

  frequencyId   String?
  frequency     Frequency? @relation(fields: [frequencyId], references: [id])

  indexPos      Int?
  status        HabitStatus   @default(ACTIVE)

  schedules     TaskSchedule[]
  completions   TaskCompletion[]
  goals         Goals[]
  categories    Categories[]
  checkpoints   CheckPoint[]
  metrics       TaskMetric[]

  @@index([indexPos])
  @@index([userId])
  @@map("task")
}

model TaskCompletion {
  id          String      @id @default(uuid())

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime? @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  completedDate DateTime  @map("completed_date")
  
  counterStep    CounterStep[]
  
  isCompleted   Boolean?  @default(false) @map("is_completed")
  
  taskId        String    @map("task_id")
  task          Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  annotations   Annotations[]
  //AGORA AS COMPLETIONS POSSUEM METRICAS 
  metrics       TaskMetricCompletion[]

  @@unique([taskId, completedDate])
  @@index([completedDate])
  @@map("task_completion")
}

model TaskSchedule {
  id            String    @unique @id @default(uuid())

  duration      String?    @db.VarChar(20)
  clock         String?    @db.VarChar(20)

  status        HabitStatus    @default(ACTIVE)

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime? @updatedAt      @map("updated_at")

  routineId     String?    @map("routine_id")
  routine       Routine?   @relation(fields: [routineId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  taskId        String?    @map("task_id")
  task          Task?      @relation(fields: [taskId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  // @@unique([routineId, clock])
  @@index([routineId, clock])
  @@map("task_schedule")
}

model TaskMetric {
  id          String      @id @default(uuid())

  emoji       String?     @db.VarChar(20)
  fieldType   MetricType? @default(NUMERIC) @map("field_type")
  field       String?     @db.VarChar(20)
  unit        String?     @db.VarChar(20)
  limit       String?
  
  updatedAt   DateTime?   @updatedAt() @map("updated_at")
  createdAt   DateTime    @default(now()) @map("created_at")
  
  // counterId   String
  // counter     Counter     @relation(fields: [counterId], references: [id])

  notes       Annotations[]

  status      HabitStatus @default(ACTIVE)

  // completionId String?        @map("completion_id")
  // completion  TaskCompletion? @relation(fields: [completionId], references: [id])

  //POSSO CRIAR UMA TASKMETRIC SEM VINCULO COM A TAREFA
  taskId  String? @map("task_id")
  task    Task? @relation(fields: [taskId], references: [id])
  taskMetricCompletion TaskMetricCompletion[]

  // @@index([date])
  @@unique([field, limit, unit, fieldType, taskId])
  @@map("task_metric")
}

model TaskMetricCompletion {
  id           String     @id @default(uuid())
  
  value        String
  // index        Int
  step         Int

  date         DateTime?
  isComplete   Boolean?   @default(false)

  // taskId       String     // ✅ NOVO
  // task         Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)

  taskMetricId String     @map("task_metric_id")
  taskMetric   TaskMetric @relation(fields: [taskMetricId], references: [id], onDelete: Cascade)

  completionId String?        @map("completion_id")
  completion  TaskCompletion? @relation(fields: [completionId], references: [id])

  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime?  @updatedAt @map("updated_at")

  // @@index([date, index])

  // 🔥 IMPORTANTE: agora inclui taskId
  // @@unique([date, index, taskMetricId, taskId])

  @@map("task_metric_completion")
}

model Post {
  id          String @id @default(uuid())
  name        String @db.VarChar(100)
  description String @db.VarChar(255)

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
  deletedAt DateTime?

  imageUrl String?  @db.VarChar(255)
  videoUrl String?  @db.VarChar(255)

  status HabitStatus @default(ACTIVE)

  userId  String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model Routine {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")

  user        User      @relation(fields: [userId], references: [id])

  name        String
  description String?

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt  @map("updated_at")

  startDate   DateTime  @default(now()) @map("start_date")
  endDate     DateTime? @map("end_date")

  cron        String?   @default("")
  frequency   Json?     @default("[\"M\",\"T\",\"W\",\"T\",\"F\",\"S\",\"S\"]")
  emoji       String?   @db.VarChar(10) @default("")

  status      HabitStatus    @default(ACTIVE)

  habitSchedules HabitSchedule[]
  taskSchedules  TaskSchedule[]

  @@map("routine")
}

model Alarm {
  id            String         @id @unique @default(uuid())
  enabled       Boolean        @default(true)
  
  // Configurações personalizadas
  triggerTime   String         // Ex: "08:00:00" ou um offset "-00:05:00"
  message       String?        // Mensagem customizada da notificação
  
  // Relacionamento
  habitScheduleId String       @map("habit_schedule_id")
  habitSchedule   HabitSchedule @relation(fields: [habitScheduleId], references: [id], onDelete: Cascade)

  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  @@map("alarms")
}

model HabitSchedule {
  id            String    @unique @id @default(uuid())

  duration      String?    @db.VarChar(20)
  clock         String?    @db.VarChar(20)

  // Agora um Schedule pode ter vários Alertas (ex: 10min antes, na hora, 5min depois)
  alarms    Alarm[]

  status        HabitStatus    @default(ACTIVE)

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime? @updatedAt      @map("updated_at")

  routineId     String?    @map("routine_id")
  routine       Routine?   @relation(fields: [routineId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  habitId       String?    @map("habit_id")
  habit         Habit?     @relation(fields: [habitId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  // @@unique([routineId, clock])
  @@index([routineId, clock])
  @@map("habit_schedule")
}

model HabitCompletion {
  id            String @id @default(uuid())

  habitId       String @map("habit_id")

  completedDate DateTime? @map("completed_date")
  counter       Int? @default(0)            // null = conta apenas 1 vez

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime? @updatedAt      @map("updated_at")

  habit       Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)
  annotations Annotations?

  @@unique([habitId, completedDate])
  @@map("habit_completions")
}

model MoodEntry {
  id      String      @id @default(uuid())
  userId  String      @map("user_id")

  moodType  String    @db.VarChar(50) @map("mood_type")
  moodLevel String    @db.VarChar(50) @map("mood_level")
  entryDate DateTime  @default(now()) @map("entry_date")
  
  createdAt DateTime  @default(now()) 
  updatedAt DateTime? @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, entryDate])
  @@index([entryDate])
  @@index([userId])
  @@map("mood_entries")
}

model Goals {
  id            String  @id @default(uuid())
  userId        String @map("user_id")

  user          User @relation(fields: [userId], references: [id])

  name          String
  description   String?
  emoji         String?   @db.VarChar(10)

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime? @updatedAt      @map("updated_at")

  habits        Habit[]

  tasks         Task[]
  checkpoints   CheckPoint[]

  status        HabitStatus? @default(ACTIVE)
  @@unique([userId, name])
  @@map("goals")
}

model Categories {
  id            String  @id @default(uuid())
  userId        String @map("user_id")

  user User @relation(fields: [userId], references: [id])

  name          String
  description   String?
  emoji         String?   @db.VarChar(10)
  color         String?   @db.VarChar(7)

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime? @updatedAt      @map("updated_at")

  habits        Habit[]
  tasks         Task[]

  status        HabitStatus? @default(ACTIVE)
  @@unique([userId, name])
  @@map("categories")
}

model Annotations {
  id           String  @id @default(uuid())
  userId       String @map("user_id")

  user         User @relation(fields: [userId], references: [id])

  name         String
  content      String?
  
  createdByAI  Boolean? @default(false) @map("created_by_ai")
  summary      String?

  imageUrl     String? @db.VarChar(255)

  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime?  @updatedAt      @map("updated_at")

  completionId String @unique @map("completion_id")
  completion       HabitCompletion @relation(fields: [completionId], references: [id], onDelete: Cascade)

  tasksCompletions TaskCompletion[]
  taskMetrics      TaskMetric[]
  @@map("annotations")
}

model Feedback {
  id          String   @id @default(uuid())

  userId      String?  @map("user_id")
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  type        FeedbackType

  title       String
  description String

  rating      Int?      @default(0)

  page        String?   @db.VarChar(200)

  imageUrl    String?   @db.VarChar(255)
  videoUrl    String?   @db.VarChar(255)

  status      FeedbackStatus @default(OPEN)

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("feedback")
}

enum FeedbackType {
  BUG
  SUGGESTION
  IMPROVEMENT
  OTHER
}

enum FeedbackStatus {
  OPEN
  REVIEWING
  CLOSED
}