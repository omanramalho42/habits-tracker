// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  // output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String @id @default(uuid())
  email       String
  
  firstName   String?
  lastName    String?
  imageUrl    String?
  
  clerkUserId String @unique
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  settings    UserSettings?
  habits      Habit[]
  tasks       Task[]
  moodEntry   MoodEntry[]
  annotations Annotations[]

  routines    Routine[]
  goals       Goals[]
  categories  Categories[]
  feedbacks   Feedback[]
  posts       Post[]
}

enum THEME {
  light
  dark
}

//TASK -> RECURRING (COMPLETION + 10) -> HABIT
//TASK -> TASKGROUPS (CATEGORIES)
//ROUTINES -> HABITS & TASKS
//ROUTINE -> GOAL


model UserSettings {
  userId String @id @map("user_id")

  bannerUrl String? @db.VarChar(255) @map("banner_url")
  avatarUrl String? @db.VarChar(255) @map("avatar_url")
  theme     THEME?  @default(dark)

  notificationsEnabled Boolean? @default(false)  @map("notifications_enabled")
  emailNotifications   Boolean? @default(false)  @map("email_notifications")
  smsNotifications     Boolean? @default(false) @map("sms_notifications")

  name      String?  @db.VarChar(100)
  email     String? @map("email")
  phone     String? @map("phone")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt      @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

enum HabitStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

model Habit {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")

  name          String    @db.VarChar(255)
  emoji         String?   @db.VarChar(10)

  customField   String?   @map("custom_field") @db.VarChar(12)
  limitCounter  Int?      @default(1)

  clock         String?   @db.VarChar(8) // HH:mm:ss       // horário definido do hábito
  duration      String?   @db.VarChar(8) //DURAÇÃO DE UM HÁBITO

  status        HabitStatus @default(ACTIVE)

  startDate     DateTime   @default(now()) @map("start_date")
  endDate       DateTime?  @map("end_date")

  reminder      Boolean?   @default(false)
  frequency     Json?      @default("[\"S\",\"M\",\"T\",\"W\",\"TH\",\"F\",\"SA\"]")
  color         String?    @default("#3B82F6") @db.VarChar(7)

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime? @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  indexPos      Int?

  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)

  schedules   HabitSchedule[]
  completions HabitCompletion[]

  goals       Goals[]
  categories  Categories[]

  @@index([indexPos])
  @@index([userId])
  @@map("habits")
}

model Task {
  id            String      @id @default(uuid())
  userId        String      @map("user_id")

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  name          String      @db.VarChar(100)
  description   String?     @db.VarChar(255)
  emoji         String?     @db.VarChar(10)
  color         String?     @db.VarChar(10)

  imageUrl      String?     @db.VarChar(255) @map("image_url")
  videoUrl      String?     @db.VarChar(255) @map("video_url")

  isPlus        Boolean?    @default(true)

  customField   String?     @map("custom_field") @db.VarChar(12)
  
  limitCounter  Int?        @default(1) @map("limit_counter")

  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime?   @updatedAt @map("updated_at")
  deletedAt     DateTime?   @map("deleted_at")

  counterId     String?
  counter       Counter? @relation(fields: [counterId], references: [id])

  cronId        String?
  cron          Cron? @relation(fields: [cronId], references: [id])
  
  frequencyId   String?
  frequency     Frequency? @relation(fields: [frequencyId], references: [id])

  indexPos      Int?
  status        HabitStatus   @default(ACTIVE)

  schedules     TaskSchedule[]
  completions   TaskCompletion[]
  goals         Goals[]
  categories    Categories[]

  checkpoints   CheckPoint[]

  @@index([indexPos])
  @@index([userId])
  @@map("task")
}

model CheckPoint {
  id          String    @id @unique @default(uuid())
  userId      String                    @map("user_id")

  name        String    @db.VarChar(100)
  description String?   @db.VarChar(255)

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt      @map("updated_at")
  deletedAt   DateTime?                 @map("deleted_at")

  startDate   DateTime  @default(now()) @map("start_date")
  endDate     DateTime?                 @map("end_date")
  
  goal  Goals[]

  tasks Task[]
  @@map("checkpoint")
}

model Counter {
  id          String  @id @default(uuid())

  label       String  @db.VarChar(20)
  emoji       String? @db.VarChar(20)

  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime?   @updatedAt @map("updated_at")
  deletedAt     DateTime?   @map("deleted_at")

  status HabitStatus  @default(ACTIVE)

  valueNumber Float?@default(0)
  valueText String?@db.VarChar(20)
  unit String?

  limit       Int     @default(1)

  taskMetric TaskMetric[]
  task       Task[]
}

model Frequency {
  id  String  @id @default(uuid())

  name          String      @db.VarChar(100)
  description   String?     @db.VarChar(255)
  emoji         String?     @db.VarChar(10)
  color         String?     @db.VarChar(10)

  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime?   @updatedAt @map("updated_at")
  deletedAt     DateTime?   @map("deleted_at")

  value Json

  task Task[]
  cron Cron[]

  status HabitStatus  @default(ACTIVE)
  
  @@map("frequencu")
}

model Cron {
  id  String  @id @default(uuid())

  name          String      @db.VarChar(50)
  description   String?     @db.VarChar(255)
  emoji         String?     @db.VarChar(10)
  color         String?     @db.VarChar(10)
  
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime?   @updatedAt @map("updated_at")
  deletedAt     DateTime?   @map("deleted_at")

  value         String

  task   Task[]
  status HabitStatus  @default(ACTIVE)

  frequency Frequency[]
  @@map("cron")
}

enum MetricType {
  NUMERIC
  STRING
  FLOAT
}

model TaskMetric {
  id        String      @id @default(uuid())

  emoji     String?     @db.VarChar(20)
  fieldType MetricType? @default(NUMERIC) @map("field_type")
  field     String?     @db.VarChar(20)
  value     String?     @db.VarChar(20) 

  date      DateTime?
  
  updatedAt DateTime?   @updatedAt() @map("updated_at")
  createdAt DateTime    @default(now()) @map("created_at")
  
  counterId String
  counter   Counter     @relation(fields: [counterId], references: [id])

  notes     Annotations[]

  completionId String?        @map("completion_id")
  completion  TaskCompletion? @relation(fields: [completionId], references: [id])

  @@index([date])
  @@map("task_metric")
}

model Post {
  id          String @id @default(uuid())
  name        String @db.VarChar(100)
  description String @db.VarChar(255)

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
  deletedAt DateTime?

  imageUrl String?  @db.VarChar(255)
  videoUrl String?  @db.VarChar(255)

  status HabitStatus @default(ACTIVE)

  userId  String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model TaskCompletion {
  id          String      @id @default(uuid())

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime? @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  completedDate DateTime  @map("completed_date")
  counter       Int?      @default(0)// null = conta apenas 1 vez
  isCompleted   Boolean?  @default(false) @map("is_completed")
  
  taskId        String    @map("task_id")
  task          Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  annotations   Annotations[]
  metrics       TaskMetric[]

  @@unique([taskId, completedDate])
  @@index([completedDate])
  @@map("task_completion")
}

model Routine {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")

  user        User      @relation(fields: [userId], references: [id])

  name        String
  description String?

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt  @map("updated_at")

  startDate   DateTime  @default(now()) @map("start_date")
  endDate     DateTime? @map("end_date")

  cron        String?   @default("")
  frequency   Json?     @default("[\"M\",\"T\",\"W\",\"T\",\"F\",\"S\",\"S\"]")
  emoji       String?   @db.VarChar(10) @default("")

  status      HabitStatus    @default(ACTIVE)

  habitSchedules HabitSchedule[]
  taskSchedules  TaskSchedule[]

  @@map("routine")
}

model TaskSchedule {
  id            String    @unique @id @default(uuid())

  duration      String?    @db.VarChar(20)
  clock         String?    @db.VarChar(20)

  status        HabitStatus    @default(ACTIVE)

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime? @updatedAt      @map("updated_at")

  routineId     String?    @map("routine_id")
  routine       Routine?   @relation(fields: [routineId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  taskId        String?    @map("task_id")
  task          Task?      @relation(fields: [taskId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  // @@unique([routineId, clock])
  @@index([routineId, clock])
  @@map("task_schedule")
}

model HabitSchedule {
  id            String    @unique @id @default(uuid())

  duration      String?    @db.VarChar(20)
  clock         String?    @db.VarChar(20)

  status        HabitStatus    @default(ACTIVE)

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime? @updatedAt      @map("updated_at")

  routineId     String?    @map("routine_id")
  routine       Routine?   @relation(fields: [routineId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  habitId       String?    @map("habit_id")
  habit         Habit?     @relation(fields: [habitId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  // @@unique([routineId, clock])
  @@index([routineId, clock])
  @@map("habit_schedule")
}

model HabitCompletion {
  id            String @id @default(uuid())

  habitId       String @map("habit_id")

  completedDate DateTime? @map("completed_date")
  counter       Int? @default(0)            // null = conta apenas 1 vez

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime? @updatedAt      @map("updated_at")

  habit       Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)
  annotations Annotations?

  @@unique([habitId, completedDate])
  @@map("habit_completions")
}

model MoodEntry {
  id      String      @id @default(uuid())
  userId  String      @map("user_id")

  moodType  String    @db.VarChar(50) @map("mood_type")
  moodLevel String    @db.VarChar(50) @map("mood_level")
  entryDate DateTime  @default(now()) @map("entry_date")
  
  createdAt DateTime  @default(now()) 
  updatedAt DateTime? @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, entryDate])
  @@index([entryDate])
  @@index([userId])
  @@map("mood_entries")
}

model Goals {
  id            String  @id @default(uuid())
  userId        String @map("user_id")

  user          User @relation(fields: [userId], references: [id])

  name          String
  description   String?
  emoji         String?   @db.VarChar(10)

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime? @updatedAt      @map("updated_at")

  habits        Habit[]

  tasks         Task[]
  checkpoints   CheckPoint[]

  status        HabitStatus? @default(ACTIVE)
  @@map("goals")
}

model Categories {
  id            String  @id @default(uuid())
  userId        String @map("user_id")

  user User @relation(fields: [userId], references: [id])

  name          String
  description   String?
  emoji         String?   @db.VarChar(10)
  color         String?   @db.VarChar(7)

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime? @updatedAt      @map("updated_at")

  habits        Habit[]
  tasks         Task[]

  status        HabitStatus? @default(ACTIVE)
  @@map("categories")
}

model Annotations {
  id           String  @id @default(uuid())
  userId       String @map("user_id")

  user         User @relation(fields: [userId], references: [id])

  name         String
  content      String?
  
  createdByAI  Boolean? @default(false) @map("created_by_ai")
  summary      String?

  imageUrl     String? @db.VarChar(255)

  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime?  @updatedAt      @map("updated_at")

  completionId String @unique @map("completion_id")
  completion       HabitCompletion @relation(fields: [completionId], references: [id], onDelete: Cascade)

  tasksCompletions TaskCompletion[]
  taskMetrics      TaskMetric[]
  @@map("annotations")
}

model Feedback {
  id          String   @id @default(uuid())

  userId      String?  @map("user_id")
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  type        FeedbackType

  title       String
  description String

  rating      Int?      @default(0)

  page        String?   @db.VarChar(200)

  imageUrl    String?   @db.VarChar(255)
  videoUrl    String?   @db.VarChar(255)

  status      FeedbackStatus @default(OPEN)

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("feedback")
}

enum FeedbackType {
  BUG
  SUGGESTION
  IMPROVEMENT
  OTHER
}

enum FeedbackStatus {
  OPEN
  REVIEWING
  CLOSED
}
